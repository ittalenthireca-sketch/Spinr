#!/bin/bash
# spinr Pre-Commit Security Hook
# Install: cp .claude/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

echo ""
echo -e "${BLUE}spinr pre-commit security check...${NC}"
BLOCKED=0

# 1. Secrets
echo "1/5 Scanning for secrets..."
PATTERNS=(
  "sk_live_[a-zA-Z0-9]+"
  "pk_live_[a-zA-Z0-9]+"
  "SUPABASE_SERVICE_ROLE_KEY\s*=\s*['\"][^'\"]{20,}"
  "sk-ant-[a-zA-Z0-9\-]+"
  "AIza[0-9A-Za-z\-_]{35}"
  "ghp_[a-zA-Z0-9]{36}"
  "password\s*[=:]\s*['\"][^'\"]{6,}"
  "DATABASE_URL.*:[^@]+@"
)
FOUND=0
for p in "${PATTERNS[@]}"; do
  M=$(git diff --cached --diff-filter=A -U0 | grep "^+" | grep -iE "$p" 2>/dev/null)
  if [ -n "$M" ]; then
    echo -e "${RED}  BLOCKED — secret detected: $p${NC}"
    FOUND=1; BLOCKED=1
  fi
done
[ $FOUND -eq 0 ] && echo -e "${GREEN}  ✅ Clean${NC}"

# 2. Forbidden files
echo "2/5 Checking forbidden files..."
FORBIDDEN=(".env" ".env.local" ".env.production" ".env.staging" "*.pem" "*.key" "serviceAccountKey.json")
FOUND=0
for f in "${FORBIDDEN[@]}"; do
  S=$(git diff --cached --name-only | grep -E "(^|/)${f//\*/[^/]*}$" 2>/dev/null)
  if [ -n "$S" ]; then
    echo -e "${RED}  BLOCKED — forbidden file: $S${NC}"
    FOUND=1; BLOCKED=1
  fi
done
[ $FOUND -eq 0 ] && echo -e "${GREEN}  ✅ Clean${NC}"

# 3. PII in logs
echo "3/5 Checking for PII in logs..."
PII_PATTERNS=(
  "print.*lat.*lng"
  "print.*latitude"
  "print.*phone"
  "console\.log.*lat.*lng"
  "console\.log.*phoneNumber"
  "logger\.(info|debug).*coordinates"
)
FOUND=0
for p in "${PII_PATTERNS[@]}"; do
  M=$(git diff --cached --diff-filter=A -U0 -- '*.py' '*.ts' '*.tsx' '*.js' | grep "^+" | grep -iE "$p" 2>/dev/null)
  if [ -n "$M" ]; then
    echo -e "${RED}  BLOCKED — PII in log: $p${NC}"
    FOUND=1; BLOCKED=1
  fi
done
[ $FOUND -eq 0 ] && echo -e "${GREEN}  ✅ Clean${NC}"

# 4. Branch protection
echo "4/5 Checking branch..."
BRANCH=$(git branch --show-current)
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  echo -e "${RED}  BLOCKED — direct commits to $BRANCH not allowed${NC}"
  BLOCKED=1
elif [ "$BRANCH" = "develop" ]; then
  echo -e "${YELLOW}  WARNING — committing directly to develop${NC}"
else
  echo -e "${GREEN}  ✅ On feature branch: $BRANCH${NC}"
fi

# 5. Float money check
echo "5/5 Checking money arithmetic..."
FLOAT=$(git diff --cached --diff-filter=A -U0 -- '*.py' '*.ts' | grep "^+" | grep -iE "(fare|price|amount|earning|payout)\s*[+\-\*\/]\s*[0-9]*\.[0-9]+" 2>/dev/null)
if [ -n "$FLOAT" ]; then
  echo -e "${YELLOW}  WARNING — possible float money arithmetic. Use Decimal or integer cents.${NC}"
else
  echo -e "${GREEN}  ✅ Clean${NC}"
fi

echo ""
if [ $BLOCKED -eq 1 ]; then
  echo -e "${RED}COMMIT BLOCKED — fix issues above${NC}"
  echo -e "${RED}Emergency bypass only: git commit --no-verify${NC}"
  exit 1
else
  echo -e "${GREEN}✅ All spinr pre-commit checks passed${NC}"
  exit 0
fi
