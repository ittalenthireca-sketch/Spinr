# ============================================================
# Spinr Admin Dashboard — Environment Variables (Next.js)
# ============================================================
# Copy this file to `.env.local` and fill in the values.
# NEXT_PUBLIC_* vars are exposed to the browser bundle — do NOT
# put server-side secrets here.
# ============================================================

# ---------- Backend API (required) ----------
# Base URL of the Spinr FastAPI backend.
# Dev default: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------- Playwright (CI / local e2e only) ----------
# PLAYWRIGHT_BASE_URL=http://localhost:3000
