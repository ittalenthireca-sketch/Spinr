# ============================================================
# Spinr Admin Dashboard — Environment Variables (Next.js)
# ============================================================
# Copy this file to `.env.local` and fill in the values.
# NEXT_PUBLIC_* vars are exposed to the browser bundle — do NOT
# put server-side secrets here.
# ============================================================

# ---------- Backend API (required) ----------
# Base URL of the Spinr FastAPI backend.
# Dev default: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------- Playwright (CI / local e2e only) ----------
# PLAYWRIGHT_BASE_URL=http://localhost:3000

# ---------- Sentry (Phase 2.2f / required in prod) ----------
# DSN for the admin-dashboard Sentry project. Picked up by
# src/instrumentation-client.ts (browser), src/sentry.server.config.ts
# (Node), and src/sentry.edge.config.ts (Edge middleware).
# Leave blank in dev — the SDK no-ops when the DSN is unset.
# NEXT_PUBLIC_SENTRY_DSN=https://<hash>@o<org>.ingest.sentry.io/<project>
# NEXT_PUBLIC_SENTRY_ENV=production
# NEXT_PUBLIC_SENTRY_RELEASE=admin-dashboard@<git-sha>
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Build-time sourcemap upload secrets (Vercel project env, not .env.local).
# SENTRY_AUTH_TOKEN=<project:write + project:releases token>
# SENTRY_ORG=<org-slug>
# SENTRY_PROJECT=spinr-admin-dashboard
