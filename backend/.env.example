# Direct Postgres URL — used ONLY by the migration path (Alembic and
# backend/scripts/run_migrations.py). Application runtime traffic goes
# through PostgREST (supabase-py) over HTTPS and does NOT read this.
DATABASE_URL=postgres://postgres.<project-ref>:<service-role-pw>@aws-0-<region>.pooler.supabase.com:5432/postgres
SPINR_ALLOW_DIRECT_DATABASE_URL=

# Auth / JWT
JWT_SECRET=replace-with-strong-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_TTL_DAYS=30
ADMIN_ACCESS_TOKEN_TTL_HOURS=12
REFRESH_TOKEN_EXPIRE_DAYS=30
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Firebase Admin
FIREBASE_SERVICE_ACCOUNT_JSON=

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006

# Admin dashboard bootstrap
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-me

# Rate limiting / WebSocket pub-sub
RATE_LIMIT_REDIS_URL=
WS_REDIS_URL=
RATE_LIMIT=10/minute

# Observability
SENTRY_DSN=

# Storage
STORAGE_BUCKET=driver-documents

# Runtime
ENV=development
