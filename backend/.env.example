# ============================================================
# Spinr Backend — Environment Variables
# ============================================================
# Copy this file to `.env` and fill in the values.
# NEVER commit real secrets. Every placeholder below must be replaced.
#
# Settings are loaded by backend/core/config.py (Pydantic BaseSettings).
# A handful of integration keys (Stripe, Twilio, SendGrid, Google Maps)
# are NOT listed here — they live in the `settings` row of the Supabase
# `settings` table and are managed from the admin dashboard.
#
# For production rotation procedure (which secrets to rotate when, and
# in what order) see docs/ops/SECRETS_ROTATION.md.
# ============================================================

# ---------- Supabase (required) ----------
# Project URL, e.g. https://your-project-ref.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co
# Service-role key — a ~220-char JWT starting with "eyJ". NEVER expose
# client-side; bypasses RLS. Rotate immediately if ever leaked. The
# production validator refuses to start if this is missing or looks
# like a placeholder.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
USE_SUPABASE=true

# Direct Postgres URL — used ONLY by the migration path (Alembic and
# backend/scripts/run_migrations.py). Application runtime traffic goes
# through PostgREST (supabase-py) over HTTPS and does NOT read this.
#
# This MUST point at the Supabase Supavisor pooler, not the direct
# cluster endpoint:
#   ✅ aws-0-<region>.pooler.supabase.com:5432   (session mode — default)
#   ✅ aws-0-<region>.pooler.supabase.com:6543   (transaction mode —
#                                                 OK for DDL, but session
#                                                 mode is safer for
#                                                 prepared statements)
#   ❌ db.<project-ref>.supabase.co:5432         (direct cluster — no
#                                                 pooling; migrations
#                                                 refuse to run unless
#                                                 SPINR_ALLOW_DIRECT_DATABASE_URL=1)
# The password is the Supabase service-role password (find it in the
# project dashboard → Database settings → Connection pooling).
# Rationale: see backend/scripts/db_url.py.
DATABASE_URL=postgres://postgres.<project-ref>:<service-role-pw>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Opt-out for the direct-cluster guard. Only set this if you genuinely
# need features the pooler doesn't support (e.g. LISTEN/NOTIFY on a CDC
# stream) for a one-off ops task. Leave BLANK in production.
SPINR_ALLOW_DIRECT_DATABASE_URL=

# ---------- Auth / JWT (REQUIRED — no default, app refuses to start without this) ----------
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# Used to sign rider/driver + admin access tokens. Rotating this value
# invalidates every outstanding access token (users get kicked back to
# login). Refresh tokens are opaque and unaffected by a JWT_SECRET
# rotation — so users with a valid refresh token re-auth silently.
JWT_SECRET=replace-with-strong-random-secret
ALGORITHM=HS256
# Rider/driver access token TTL, in days. Default 30. Drop to 1-7 once
# the mobile apps ship refresh-token support (see utils/refresh_tokens).
ACCESS_TOKEN_TTL_DAYS=30
# Admin dashboard access token TTL, in hours. Default 12.
ADMIN_ACCESS_TOKEN_TTL_HOURS=12
# Refresh token TTL, in days. Default 30.
REFRESH_TOKEN_EXPIRE_DAYS=30
# Legacy — not read at runtime; kept for backward compat with docs.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---------- Firebase Admin (required for push + phone auth verify) ----------
# Paste the entire service-account JSON on a single line (or use
# $(cat service-account.json | tr -d '\n') in your shell).
FIREBASE_SERVICE_ACCOUNT_JSON=

# ---------- CORS ----------
# Comma-separated origins. Use "*" ONLY in local dev — the production
# validator refuses to boot with wildcard + ENV=production.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006

# ---------- Admin dashboard bootstrap credentials ----------
# ADMIN_PASSWORD is REQUIRED — no default, app refuses to start without this.
# Used for first-time admin login; change immediately after first login.
# Use a strong password (12+ chars). Weak values ("admin123", "password",
# "changeme", "replace-me") are rejected in production by both the
# Pydantic loader (core/config.py) and the startup validator
# (core/middleware.py).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-me

# ---------- Rate limiting / WebSocket pub-sub (required in production) ----------
# Shared Redis URL backing the SlowAPI rate limiter. Without this, each
# Fly machine keeps its own counters and an attacker can sidestep OTP
# / login limits by riding LB stickiness. Production validator requires
# a redis:// or rediss:// URL.
# Example: rediss://default:<password>@fly-spinr-redis.upstash.io:6379
RATE_LIMIT_REDIS_URL=
# Redis URL for WebSocket cross-machine fan-out (audit P0-B3). If empty
# the backend reuses RATE_LIMIT_REDIS_URL — configure two only if you
# want to isolate WS traffic onto a separate Redis instance.
WS_REDIS_URL=
RATE_LIMIT=10/minute

# ---------- Observability ----------
# SENTRY_DSN: REQUIRED when ENV=production (Phase 2.2 / audit T1). The
# prod validator in core/middleware.py refuses to boot without it so
# unhandled exceptions never silently disappear into loguru-only logs.
# Optional in dev — leave blank to skip Sentry init entirely.
SENTRY_DSN=
# Optional overrides for Sentry sampling. Defaults (0.1) are fine for
# most deploys; lower if you're burning Sentry quota, higher if you're
# debugging a specific release.
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1
# Optional explicit release tag. Leave blank on Fly — FLY_IMAGE_REF is
# picked up automatically and gives per-deployment granularity.
# SENTRY_RELEASE=

# /metrics endpoint protection (Phase 2.3e / audit T3). At least ONE of
# METRICS_BEARER_TOKEN or METRICS_IP_ALLOWLIST MUST be set in production
# — the startup validator refuses to boot otherwise. Dev (ENV!=production)
# can leave both blank and the endpoint falls through (useful for local
# Grafana).
#
# Bearer token — Prometheus scrape config uses bearer_token_file. Generate
# with `openssl rand -hex 32`.
# METRICS_BEARER_TOKEN=
#
# IP allow-list — comma-separated CIDRs. For Fly internal scraping, use
# the 6PN private range. For a specific Prometheus IP, use /32.
# METRICS_IP_ALLOWLIST=fd00::/8,10.0.0.0/8

# ---------- Storage ----------
STORAGE_BUCKET=driver-documents

# ---------- Logging (Phase 2.7 / audit T10) ----------
# LOG_LEVEL overrides the per-ENV default (DEBUG for dev/staging, INFO
# for production). Use to increase verbosity on a live machine during
# incident triage — remember to unset it afterwards or you'll saturate
# your log-drain budget (roughly 100–200 MB/day extra at DEBUG vs INFO).
# APP_PROCESS is set automatically by worker.py ("worker"); the API
# lifespan leaves it as "api". Override only in unusual topologies.
# LOG_LEVEL=INFO
# APP_PROCESS=api

# ---------- Runtime ----------
# Must be "production" when deployed; "development" skips the strict
# startup validator and allows wildcard CORS, memory-backed rate limits,
# etc. Do NOT set this to anything other than "production" on Fly.
ENV=development
DEBUG=false
