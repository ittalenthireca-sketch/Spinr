# ============================================================
# Spinr Backend — Environment Variables
# ============================================================
# Copy this file to `.env` and fill in the values.
# NEVER commit real secrets. Every placeholder below must be replaced.
#
# Settings are loaded by backend/core/config.py (Pydantic BaseSettings).
# A handful of integration keys (Stripe, Twilio, SendGrid, Google Maps)
# are NOT listed here — they live in the `settings` row of the Supabase
# `settings` table and are managed from the admin dashboard.
#
# For production rotation procedure (which secrets to rotate when, and
# in what order) see docs/ops/SECRETS_ROTATION.md.
# ============================================================

# ---------- Supabase (required) ----------
# Project URL, e.g. https://your-project-ref.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co
# Service-role key — a ~220-char JWT starting with "eyJ". NEVER expose
# client-side; bypasses RLS. Rotate immediately if ever leaked. The
# production validator refuses to start if this is missing or looks
# like a placeholder.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
USE_SUPABASE=true

# ---------- Auth / JWT (required) ----------
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# Used to sign rider/driver + admin access tokens. Rotating this value
# invalidates every outstanding access token (users get kicked back to
# login). Refresh tokens are opaque and unaffected by a JWT_SECRET
# rotation — so users with a valid refresh token re-auth silently.
JWT_SECRET=replace-with-strong-random-secret
ALGORITHM=HS256
# Rider/driver access token TTL, in days. Default 30. Drop to 1-7 once
# the mobile apps ship refresh-token support (see utils/refresh_tokens).
ACCESS_TOKEN_TTL_DAYS=30
# Admin dashboard access token TTL, in hours. Default 12.
ADMIN_ACCESS_TOKEN_TTL_HOURS=12
# Refresh token TTL, in days. Default 30.
REFRESH_TOKEN_EXPIRE_DAYS=30
# Legacy — not read at runtime; kept for backward compat with docs.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---------- Firebase Admin (required for push + phone auth verify) ----------
# Paste the entire service-account JSON on a single line (or use
# $(cat service-account.json | tr -d '\n') in your shell).
FIREBASE_SERVICE_ACCOUNT_JSON=

# ---------- CORS ----------
# Comma-separated origins. Use "*" ONLY in local dev — the production
# validator refuses to boot with wildcard + ENV=production.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006

# ---------- Admin dashboard bootstrap credentials ----------
# Used for first-time admin login. Change immediately after first login.
# Production refuses to start if these are left at defaults.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-me

# ---------- Rate limiting / WebSocket pub-sub (required in production) ----------
# Shared Redis URL backing the SlowAPI rate limiter. Without this, each
# Fly machine keeps its own counters and an attacker can sidestep OTP
# / login limits by riding LB stickiness. Production validator requires
# a redis:// or rediss:// URL.
# Example: rediss://default:<password>@fly-spinr-redis.upstash.io:6379
RATE_LIMIT_REDIS_URL=
# Redis URL for WebSocket cross-machine fan-out (audit P0-B3). If empty
# the backend reuses RATE_LIMIT_REDIS_URL — configure two only if you
# want to isolate WS traffic onto a separate Redis instance.
WS_REDIS_URL=
RATE_LIMIT=10/minute

# ---------- Observability (optional) ----------
SENTRY_DSN=

# ---------- Storage ----------
STORAGE_BUCKET=driver-documents

# ---------- Runtime ----------
# Must be "production" when deployed; "development" skips the strict
# startup validator and allows wildcard CORS, memory-backed rate limits,
# etc. Do NOT set this to anything other than "production" on Fly.
ENV=development
DEBUG=false
