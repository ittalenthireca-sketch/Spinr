{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping the Spinr API and worker.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "title": "Spinr — Production Overview",
  "uid": "spinr-overview",
  "description": "Phase 2.3f of the production-readiness audit. Five key gauges + latency/availability from the FastAPI instrumentator. Alerts driven off burn-rate rules defined separately in Phase 2.4.",
  "tags": ["spinr", "production", "overview"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "label": "Datasource"
      },
      {
        "name": "env",
        "type": "custom",
        "label": "Environment",
        "query": "production,staging",
        "current": { "text": "production", "value": "production" },
        "options": [
          { "text": "production", "value": "production", "selected": true },
          { "text": "staging", "value": "staging", "selected": false }
        ]
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Availability & latency (FastAPI)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "API request rate by method",
      "description": "From prometheus-fastapi-instrumentator. Rate of HTTP requests grouped by method.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (method) (rate(http_requests_total[1m]))",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "API p95 latency by handler",
      "description": "99th-percentile request latency per FastAPI handler. Alerting SLO is typically 500ms for p95 on write paths; see Phase 2.4.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (handler, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{handler}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP error rate (5xx)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(http_requests_total{status=~\"5..\"}[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "WebSocket connections by role",
      "description": "spinr_ws_connections — updated by ConnectionManager on connect/disconnect. Sudden drops usually indicate a deploy; gradual drops can mean client-side reconnection bugs.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 30, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (role) (spinr_ws_connections)",
          "legendFormat": "{{role}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Ride pipeline",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Active rides by status",
      "description": "spinr_active_rides — counts of rides in non-terminal states. The dispatch funnel: searching → driver_assigned → driver_accepted → in_progress. Refreshed every 30s by metrics_refresh_loop.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 25, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "spinr_active_rides",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Ride dispatch latency (p50 / p95)",
      "description": "spinr_ride_dispatch_latency_seconds — wall time from ride request to driver_assigned. SLO: p95 < 30s.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(spinr_ride_dispatch_latency_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(spinr_ride_dispatch_latency_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Async queues & background tasks",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Stripe event queue depth",
      "description": "spinr_stripe_queue_depth — unprocessed rows in stripe_events. Steady state is near-zero. Growth indicates the worker is falling behind; sustained > 50 is an alert (Phase 2.4).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 25 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "spinr_stripe_queue_depth",
          "legendFormat": "unprocessed"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Background task heartbeat age",
      "description": "spinr_bg_task_heartbeat_age_seconds — seconds since each loop last reported in. Alert fires at 2 × expected_interval_seconds; the /health/deep endpoint flips to 503 at the same threshold.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 25 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "spinr_bg_task_heartbeat_age_seconds",
          "legendFormat": "{{task_name}}"
        }
      ]
    },
    {
      "id": 23,
      "type": "stat",
      "title": "Background task last status",
      "description": "spinr_bg_task_last_status — 0=ok, 1=error. Red cell = the loop ran but threw; pair with heartbeat age to tell 'loop crashed' apart from 'worker wedged'.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 32 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "ok", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "error", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "spinr_bg_task_last_status",
          "legendFormat": "{{task_name}}"
        }
      ]
    }
  ]
}
