# ============================================================
# Spinr Rider App — Environment Variables (Expo)
# ============================================================
# Copy this file to `.env` and fill in the values.
# All EXPO_PUBLIC_* vars are embedded in the JS bundle and visible
# to end users — do NOT put server-side secrets here.
# ============================================================

# ---------- Google Maps (required) ----------
# Enable on your key: Maps SDK for Android, Maps SDK for iOS,
# Places API, Directions API, Geocoding API.
# Restrict the key to your Android package name + iOS bundle id
# in Google Cloud Console before shipping.
#
# Local dev: set in this .env file.
# EAS Build / production: register the key as an EAS Secret so it
# never lands in git or eas.json:
#   eas secret:create --scope project \
#     --name EXPO_PUBLIC_GOOGLE_MAPS_API_KEY \
#     --value <your-restricted-key>
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ---------- Backend URL ----------
# Dev: can be omitted — shared/config/spinr.config.ts auto-detects
#      the host from Expo's hostUri.
# Physical device: set to http://<your-LAN-ip>:8000
# Production builds: set to your deployed backend URL.
# EXPO_PUBLIC_BACKEND_URL=http://192.168.1.10:8000

# Alternate alias (a few screens still read this directly).
# EXPO_PUBLIC_API_URL=http://192.168.1.10:8000

# ---------- Stripe (optional until payments are wired end-to-end) ----------
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ---------- Firebase Web SDK (only needed for Expo Web + Expo Go) ----------
# Native iOS/Android builds read google-services.json /
# GoogleService-Info.plist and ignore these. These values are not
# secrets (Firebase web configs are bundled into every client), but
# they're kept in env so a cloned repo doesn't accidentally write
# to the original project.
# EXPO_PUBLIC_FIREBASE_API_KEY=
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project
# EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
# EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
# EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
# EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
