# ============================================================
# Spinr Rider App — Environment Variables (Expo)
# ============================================================
# Copy this file to `.env` and fill in the values.
# All EXPO_PUBLIC_* vars are embedded in the JS bundle and visible
# to end users — do NOT put server-side secrets here.
# ============================================================

# ---------- Google Maps (required) ----------
# Enable on your key: Maps SDK for Android, Maps SDK for iOS,
# Places API, Directions API, Geocoding API.
# Restrict the key to your Android package name + iOS bundle id
# in Google Cloud Console before shipping.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ---------- Backend URL ----------
# Dev: can be omitted — shared/config/spinr.config.ts auto-detects
#      the host from Expo's hostUri.
# Physical device: set to http://<your-LAN-ip>:8000
# Production builds: set to your deployed backend URL.
# EXPO_PUBLIC_BACKEND_URL=http://192.168.1.10:8000

# Alternate alias (a few screens still read this directly).
# EXPO_PUBLIC_API_URL=http://192.168.1.10:8000

# ---------- Stripe (optional until payments are wired end-to-end) ----------
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
